# App
TOCKY_DEBUG=true

# Database
TOCKY_DATABASE_URL=postgresql+asyncpg://tocky:tocky@localhost:5432/tocky

# JWT Authentication (ES256 ECDSA keys)
# Generate with: openssl ecparam -genkey -name prime256v1 -noout -out private.pem && openssl ec -in private.pem -pubout -out public.pem
TOCKY_JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
<paste private key here>
-----END EC PRIVATE KEY-----"

TOCKY_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<paste public key here>
-----END PUBLIC KEY-----"

NEXT_PUBLIC_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<paste public key here>
-----END PUBLIC KEY-----"

# Alibaba Cloud DashScope
TOCKY_DASHSCOPE_API_KEY=
TOCKY_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
TOCKY_QWEN_MODEL_NAME=qwen2.5-omni-7b

# Per-workload model selection (leave blank to use TOCKY_QWEN_MODEL_NAME for all)
TOCKY_QWEN_TRANSCRIPTION_MODEL=qwen3-asr-flash
TOCKY_QWEN_CLASSIFICATION_MODEL=qwen3.5-flash
TOCKY_QWEN_SOAP_MODEL=qwen3.5-plus
TOCKY_QWEN_EXTRACTION_MODEL=qwen3.5-flash

# DashScope Streaming ASR (real-time transcription via WebSocket)
# Regional: wss://dashscope.aliyuncs.com (Beijing), wss://dashscope-intl.aliyuncs.com (SG)
TOCKY_DASHSCOPE_WS_BASE_URL=wss://dashscope-intl.aliyuncs.com
TOCKY_QWEN_STREAMING_ASR_MODEL=qwen3-asr-flash-realtime

# Server VAD turn detection tuning
# threshold: [-1, 1] sensitivity; higher = less sensitive to background noise
# silence_duration_ms: [200, 6000] ms of silence before a segment is committed
# prefix_padding_ms: audio padding before detected speech onset
TOCKY_VAD_THRESHOLD=0.5
TOCKY_VAD_SILENCE_DURATION_MS=1200
TOCKY_VAD_PREFIX_PADDING_MS=300

# Sandbox mode (fake AI responses, zero API cost)
TOCKY_SANDBOX_AI=false
TOCKY_SANDBOX_AI_LATENCY=0.2

# Audio storage — configure ONE of S3 or OSS (S3 checked first)

# S3-compatible storage (Cloudflare R2, AWS S3, MinIO, etc.)
TOCKY_S3_ENDPOINT_URL=
TOCKY_S3_ACCESS_KEY_ID=
TOCKY_S3_ACCESS_KEY_SECRET=
TOCKY_S3_BUCKET_NAME=tocky-audio
TOCKY_S3_REGION=auto
TOCKY_S3_PUBLIC_URL=

# Alibaba Cloud OSS (alternative)
TOCKY_OSS_ACCESS_KEY_ID=
TOCKY_OSS_ACCESS_KEY_SECRET=
TOCKY_OSS_BUCKET_NAME=tocky-audio
TOCKY_OSS_ENDPOINT=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
