# Database
TOCKY_DATABASE_URL=postgresql+asyncpg://tocky:tocky@localhost:5432/tocky

# Authentication
TOCKY_AUTH_SECRET=change-me-to-a-random-secret

# Alibaba Cloud DashScope (Qwen2.5-Omni)
TOCKY_DASHSCOPE_API_KEY=
TOCKY_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TOCKY_QWEN_MODEL_NAME=qwen2.5-omni-7b

# Alibaba Cloud OSS (audio storage)
TOCKY_OSS_ACCESS_KEY_ID=
TOCKY_OSS_ACCESS_KEY_SECRET=
TOCKY_OSS_BUCKET_NAME=tocky-audio
TOCKY_OSS_ENDPOINT=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
